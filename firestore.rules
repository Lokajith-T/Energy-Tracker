// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - email: string (required)
//   - tariff: number (optional)
//   - usageLimit: number (optional)
//   - currentUnits: number (optional)
//   - consumerType: string (optional, 'domestic' or 'commercial')
//
// Collection: energy_stats
// Document ID: live
// Fields:
//   - voltage: number
//   - current: number
//   - power: number
//   - units: number
//   - lastUpdated: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('tariff' in data) || data.tariff is number) &&
             (!('usageLimit' in data) || data.usageLimit is number) &&
             (!('currentUnits' in data) || data.currentUnits is number) &&
             (!('consumerType' in data) || data.consumerType in ['domestic', 'commercial']);
    }

    function isValidEnergyStats(data) {
      return data.voltage is number &&
             data.current is number &&
             data.power is number &&
             data.units is number;
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
    
    match /energy_stats/live {
      allow read: if isAuthenticated();
      // In a real app, only a backend/hardware would write this.
      // For this demo, we'll allow authenticated users to update it to simulate live data.
      allow write: if isAuthenticated() && isValidEnergyStats(request.resource.data);
    }
  }
}
